<Window x:Class="PalworldLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PalworldLauncher"
        mc:Ignorable="d"
        Title="Odd Palworld Launcher" Height="580" Width="880"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Icon="logo.ico">
    
    <Window.Resources>
        <!-- Modern Neon Fonts and Colors -->
        <SolidColorBrush x:Key="BgDark" Color="#0B0914" />
        <SolidColorBrush x:Key="BgMedium" Color="#131024" />
        <SolidColorBrush x:Key="BgGlass" Color="#1F1A3A" />
        <SolidColorBrush x:Key="AccentCyan" Color="#00F0FF" />
        <SolidColorBrush x:Key="AccentPurple" Color="#A100FF" />
        <SolidColorBrush x:Key="AccentGreen" Color="#00FF66" />
        <SolidColorBrush x:Key="AccentRed" Color="#FF3366" />
        <SolidColorBrush x:Key="TextLight" Color="#F5F5F7" />
        <SolidColorBrush x:Key="TextMuted" Color="#8E8E93" />

        <!-- Glow Shadow Effects -->
        <DropShadowEffect x:Key="GlowCyan" Color="#00F0FF" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="GlowPurple" Color="#A100FF" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
        <DropShadowEffect x:Key="ButtonGlow" Color="#00F0FF" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>

        <!-- Custom TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#17142E"/>
            <Setter Property="BorderBrush" Value="#2F2B4E"/>
            <Setter Property="Foreground" Value="#F5F5F7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4C457F"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00F0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom PasswordBox Style -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#17142E"/>
            <Setter Property="BorderBrush" Value="#2F2B4E"/>
            <Setter Property="Foreground" Value="#F5F5F7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4C457F"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00F0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Scrollbar/Buttons and other assets -->
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8E8E93"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A244A"/>
                    <Setter Property="Foreground" Value="#F5F5F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseWindowButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3366"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Play Button Style -->
        <Style x:Key="PlayButton" TargetType="Button">
            <Setter Property="Foreground" Value="#0A0915"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Effect" Value="{StaticResource ButtonGlow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" CornerRadius="24" Background="#00F0FF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#33F3FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Background" Value="#332F4E"/>
                                <Setter Property="Foreground" Value="#8E8E93"/>
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Action Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F5F5F7"/>
            <Setter Property="Background" Value="#24203F"/>
            <Setter Property="BorderBrush" Value="#3D3766"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#312B54"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00F0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#17142D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" BorderThickness="1" BorderBrush="#2F2B4E" ClipToBounds="True">
        <!-- Main Window Background -->
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#08070F" Offset="0.0"/>
                <GradientStop Color="#141126" Offset="0.5"/>
                <GradientStop Color="#1A1530" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/> <!-- Custom Title Bar -->
                <RowDefinition Height="*"/>  <!-- Main Content -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#0C0A15" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Ellipse Width="8" Height="8" Fill="#00F0FF" Margin="0,0,10,0" Effect="{StaticResource GlowCyan}"/>
                    <TextBlock Text="ODD PALWORLD LAUNCHER" Foreground="#F5F5F7" FontWeight="Bold" FontSize="11"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="—" Style="{StaticResource WindowButton}" Click="MinimizeButton_Click"/>
                    <Button Content="✕" Style="{StaticResource CloseWindowButton}" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/> <!-- Left Panel: Configurations -->
                    <ColumnDefinition Width="*"/>   <!-- Right Panel: Play Dashboard -->
                </Grid.ColumnDefinitions>

                <!-- Left Configuration Panel with Palworld Image Above Settings -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/> <!-- Upper half for the image -->
                        <RowDefinition Height="12"/>  <!-- Gap -->
                        <RowDefinition Height="*"/>   <!-- Lower half for settings -->
                    </Grid.RowDefinitions>

                    <!-- Palworld Header Image with Rounded Corners -->
                    <Border Grid.Row="0" BorderBrush="#1C1833" BorderThickness="1" CornerRadius="12">
                        <Border.Background>
                            <ImageBrush ImageSource="Palworld.jpg" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <!-- Launcher Settings Block -->
                    <Border Grid.Row="2" Background="#110E21" BorderBrush="#1C1833" BorderThickness="1" CornerRadius="12" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="LAUNCHER SETTINGS" Foreground="#F5F5F7" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                                <!-- Palworld Folder Path -->
                                <TextBlock Text="Palworld Installation Folder" Foreground="#8E8E93" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtPalworldPath" Grid.Column="0" ToolTip="Select the root Palworld game folder containing Palworld.exe"/>
                                    <Button Grid.Column="1" Content="Browse..." Style="{StaticResource SecondaryButton}" Margin="6,0,0,0" Click="BrowsePath_Click"/>
                                </Grid>

                                <!-- Manifest URL -->
                                <TextBlock Text="Remote Manifest URL (Mod Settings)" Foreground="#8E8E93" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtManifestUrl" Margin="0,0,0,16" ToolTip="URL of the JSON manifest for community mods"/>

                                <Button Content="Save Launcher Settings" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Padding="0,10" FontWeight="SemiBold" Click="SaveSettings_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Action Panel / Play Dashboard -->
                <Grid Grid.Column="1" Margin="24,0,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title / Welcome -->
                        <RowDefinition Height="*"/>    <!-- Graphic / Info -->
                        <RowDefinition Height="Auto"/> <!-- Status / Progress -->
                        <RowDefinition Height="Auto"/> <!-- Main Play Button -->
                    </Grid.RowDefinitions>

                    <!-- Title & Server Status -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="READY FOR ACTION" Foreground="#8E8E93" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="Palworld Dedicated Server" Foreground="#F5F5F7" FontSize="26" FontWeight="ExtraBold" Margin="0,4,0,12"/>

                        <!-- Online Indicator Badge -->
                        <Border HorizontalAlignment="Left" CornerRadius="12" Padding="12,6" Background="#161F25" BorderBrush="#253C3C" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#FF3366" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtServerStatus" Text="Checking server status..." Foreground="#8E8E93" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Center Display (Dynamic Info / Log) -->
                    <Border Grid.Row="1" Background="#0C0A15" BorderBrush="#1C1833" BorderThickness="1" CornerRadius="12" Margin="0,8,0,20" Padding="16">
                        <Grid>
                            <TextBlock Text="Mod Sync &amp; Verification Console" Foreground="#4A4475" FontSize="11" FontWeight="Bold" VerticalAlignment="Top"/>
                            <TextBox x:Name="TxtConsoleLog" 
                                     Foreground="#00F0FF" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     IsReadOnly="True" 
                                     AcceptsReturn="True" 
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" 
                                     Margin="0,20,0,0"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Text="[Console Ready] Waiting to verify mods...&#x0a;Click 'Sync &amp; Play' to begin mod cleanup and synchronization."/>
                        </Grid>
                    </Border>

                    <!-- Status Display & Progress Bar -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <Grid Margin="0,0,0,8">
                            <TextBlock x:Name="TxtStatus" Text="Ready to launch" Foreground="#F5F5F7" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPercent" Text="0%" Foreground="#00F0FF" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- Custom styled Progress Bar -->
                        <ProgressBar x:Name="PrgProgress" Height="8" Value="0" Background="#1C1833" Foreground="#00F0FF" BorderThickness="0">
                            <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Grid x:Name="TemplateRoot">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                        <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="4" HorizontalAlignment="Left"/>
                                    </Grid>
                                </ControlTemplate>
                            </ProgressBar.Template>
                        </ProgressBar>
                    </StackPanel>

                    <!-- Large Play Button -->
                    <Button x:Name="BtnPlay" Grid.Row="3" Content="SYNC &amp; PLAY" Height="60" Style="{StaticResource PlayButton}" Margin="0,0,0,10" Click="BtnPlay_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
